          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(mc_players_online_total{server_name=~\"$server\"})",
        "instant": true, "legendFormat": "Gesamt", "refId": "A" }],
      "title": "Spieler Online", "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
